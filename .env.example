# TetraMem-XL 环境变量模板

# 基础配置
TETRAMEM_STORAGE=./tetramem_data_v2
TETRAMEM_UI_PASSWORD=CHANGE_ME
TETRAMEM_HOST=0.0.0.0
TETRAMEM_PORT=8000
TETRAMEM_CORS_ORIGINS=*

# 晶格参数
TETRAMEM_RESOLUTION=5
TETRAMEM_SPACING=1.0
TETRAMEM_SECRET_KEY=
TETRAMEM_CHECKPOINT_INTERVAL=300

# 日志
LOG_LEVEL=INFO

# Observer 配置
TETRAMEM_OBSERVER_ENABLED=true
TETRAMEM_OBSERVER_WINDOW=300
TETRAMEM_OBSERVER_MAX_STORES=30
TETRAMEM_OBSERVER_LOG_PATH=
